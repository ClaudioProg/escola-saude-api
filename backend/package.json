{
  "name": "escoladasaude-backend",
  "version": "2.0.0",
  "description": "Backend da Plataforma Escola da Saúde - eventos, inscrições, presenças, avaliações, certificados, agenda e relatórios.",
  "main": "src/server.js",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:clean": "npx kill-port 3000 || true",
    "dev:reset": "npx kill-port 3000 || true && nodemon src/server.js",

    "health": "node -e \"fetch('http://localhost:3000/__ping').then(r=>r.text()).then(console.log).catch(err=>{console.error(err);process.exit(1)})\"",
    "version:local": "node -e \"fetch('http://localhost:3000/__version').then(r=>r.text()).then(console.log).catch(err=>{console.error(err);process.exit(1)})\"",

    "migrate": "node scripts/run-migration.js --dir db/migration --pattern \"*.sql\"",
    "migrate:dry": "node scripts/run-migration.js --dir db/migration --pattern \"*.sql\" --dry-run",
    "migrate:file": "node scripts/run-migration.js --file",

    "test": "node -e \"console.log('No tests configured yet')\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "canvas": "^3.2.0",
    "compression": "^1.8.1",
    "cookie": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.3",
    "pdfkit": "^0.17.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.2"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.10"
  }
}