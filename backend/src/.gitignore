# ============================================================
# .gitignore — Escola da Saúde
# Projeto Node / Backend / Plataforma
# ============================================================

# ─────────────────────────────────────────────
# Dependências
# ─────────────────────────────────────────────
node_modules/

# ─────────────────────────────────────────────
# Ambiente / segredos
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample

# ─────────────────────────────────────────────
# Logs / runtime
# ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# ─────────────────────────────────────────────
# Sistema operacional
# ─────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini

# ─────────────────────────────────────────────
# Editor / IDE
# ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.code-workspace
.history/

# ─────────────────────────────────────────────
# Build / output
# ─────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
public/build/

# ─────────────────────────────────────────────
# Bundlers / cache
# ─────────────────────────────────────────────
.vite/
node_modules/.vite/
.tailwindcache
.parcel-cache/
.cache/
.turbo/
.tmp/
temp/
tmp/

# ─────────────────────────────────────────────
# Testes / cobertura
# ─────────────────────────────────────────────
coverage/
.nyc_output/
.vitest/
playwright-report/
test-results/
cypress/videos/
cypress/screenshots/

# ─────────────────────────────────────────────
# Artefatos locais / storage gerado
# ─────────────────────────────────────────────
data/
.data/
uploads/
certificados/
storage/
backups/
var/

# ─────────────────────────────────────────────
# Probes / arquivos auxiliares de runtime
# ─────────────────────────────────────────────
.probe/
.probe-*
*.probe

# ─────────────────────────────────────────────
# Banco local / SQLite / dumps
# ─────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
*.dump
*.backup
*.sql.gz

# ─────────────────────────────────────────────
# Certificados / chaves locais
# ─────────────────────────────────────────────
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# ─────────────────────────────────────────────
# Plataformas / deploy local
# ─────────────────────────────────────────────
.vercel/
.render/
.neon/

# ─────────────────────────────────────────────
# Temporários / conflitos / backups
# ─────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej

# ─────────────────────────────────────────────
# Compactados locais
# ─────────────────────────────────────────────
*.zip
*.rar
*.7z
*.tar
*.gz